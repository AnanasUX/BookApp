<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.BookApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#FF6B1A</item>
        <item name="colorPrimaryVariant">#E84D00</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#FFB800</item>
        <item name="android:windowBackground">#121212</item>
        <item name="android:statusBarColor">#121212</item>
        <item name="android:navigationBarColor">#121212</item>
    </style>

    <style name="NavItem" parent="">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:gap">4dp</item>
    </style>
</resources>
